[ControlFlags]
ExcludeFromSelect.nt=*  ; Initialization of all display model-specfic information 

[TPLCDVGA.Install]                     ; VGA 4:3 640x480
DelReg=DEL_CURRENT_REG
AddReg=640, DPMS, ICM
CopyFiles=TPLCD.CopyFiles

[TPLCDVGA.Install.Services]
AddService = monitor, %SPSVCINST_ASSOCSERVICE%, Monitor_Service.Install   ; install monitor class function driver

[TPLCDSVGA.Install]                    ; SVGA 4:3 800x600
DelReg=DEL_CURRENT_REG
AddReg=800, DPMS, ICM
CopyFiles=TPLCD.CopyFiles

[TPLCDSVGA.Install.Services]
