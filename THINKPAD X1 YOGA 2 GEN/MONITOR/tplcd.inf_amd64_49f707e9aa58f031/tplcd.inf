; Monitor class function driver loading parameters
[Monitor_Service.Install]
DisplayName    = %Monitor.SVCDESC%
ServiceType    = 1               ; SERVICE_KERNEL_DRIVER
StartType      = 3               ; SERVICE_DEMAND_START
ErrorControl   = 1               ; SERVICE_ERROR_NORMAL
ServiceBinary  = %12%\monitor.sys

[DEL_CURRENT_REG]                      ; for other than 2nd LCD
HKR,MODES
HKR,,MaxResolution
HKR,,DPMS
HKR,,ICMProfile
HKR,,ICMProfileAC
HKR,,DisplayHdrLevel
;; HKLM,"Software\Lenovo\LenovoDisplayPanel"

[DEL_CURRENT_REG1]                     ; for 2nd LCD
HKR,MODES
HKR,,MaxResolution
HKR,,DPMS
HKR,,ICMProfile
HKR,,ICMProfileAC


